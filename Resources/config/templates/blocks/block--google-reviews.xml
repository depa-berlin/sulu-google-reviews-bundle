<?xml version="1.0" ?>
<template xmlns="http://schemas.sulu.io/template/template"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">

    <key>block--google-reviews</key>

    <meta>
        <title lang="en">Google Reviews</title>
        <title lang="de">Google Bewertungen</title>
    </meta>

    <properties>
        <property name="title" type="text_line">
            <meta>
                <title lang="en">Title</title>
                <title lang="de">Titel</title>
            </meta>
        </property>

        <property name="limit" type="number">
            <meta>
                <title lang="en">Number of reviews</title>
                <title lang="de">Anzahl der Bewertungen</title>
            </meta>
            <params>
                <param name="min" value="1"/>
                <param name="step" value="1"/>
            </params>
        </property>

        <property name="sort" type="single_select">
            <meta>
                <title lang="en">Sorting</title>
                <title lang="de">Sortierung</title>
            </meta>
            <params>
                <param name="default_value" value="date"/>
                <param name="values" type="collection">
                    <param name="date">
                        <meta>
                            <title lang="en">By date (newest first)</title>
                            <title lang="de">Nach Datum (neueste zuerst)</title>
                        </meta>
                    </param>
                    <param name="rating">
                        <meta>
                            <title lang="en">By rating (highest first)</title>
                            <title lang="de">Nach Bewertung (höchste zuerst)</title>
                        </meta>
                    </param>
                    <param name="custom">
                        <meta>
                            <title lang="en">Custom order</title>
                            <title lang="de">Eigene Reihenfolge</title>
                        </meta>
                    </param>
                </param>
            </params>
        </property>

        <property name="emptyText" type="text_line">
            <meta>
                <title lang="en">Text when no reviews are available</title>
                <title lang="de">Text, wenn keine Bewertungen vorhanden sind</title>
            </meta>
        </property>
    </properties>
</template>
