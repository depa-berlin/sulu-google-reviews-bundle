<?xml version="1.0" ?>
<form xmlns="http://schemas.sulu.io/template/template"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/form-1.0.xsd">

    <key>google_review_details</key>

    <properties>
        <section name="review">
            <meta>
                <title lang="de">Bewertung (automatisch von Google importiert)</title>
                <title lang="en">Review (automatically imported from Google)</title>
            </meta>
            <properties>
                <property name="reviewDisplay" type="google_review_display" colspan="12">
                    <meta>
                        <title lang="de">Bewertung</title>
                        <title lang="en">Review</title>
                    </meta>
                </property>
            </properties>
        </section>

        <section name="moderation">
            <meta>
                <title lang="de">Moderation &amp; Darstellung</title>
                <title lang="en">Moderation &amp; Display</title>
            </meta>
            <properties>
                <property name="moderation" type="google_review_moderation" colspan="12"/>
            </properties>
        </section>
    </properties>
</form>
