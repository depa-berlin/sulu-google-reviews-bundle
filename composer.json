{
    "name": "depa/sulu-google-reviews-bundle",
    "description": "Fetches and displays Google Places reviews in Sulu CMS with admin moderation",
    "type": "symfony-bundle",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "sulu/sulu": "^3.0",
        "symfony/config": "^7.0",
        "symfony/dependency-injection": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/http-client": "^7.0",
        "symfony/http-kernel": "^7.0",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/orm": "^3.0",
        "twig/twig": "^3.9",
        "nesbot/carbon": "^2.72 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpstan/phpstan-doctrine": "^2.0"
    },
    "suggest": {
        "robole/sulu-ai-translator-bundle": "Provides a DeepL-based translator that can be bound to ReviewTranslatorInterface for the sulu:google-reviews:translate-missing command"
    },
    "autoload": {
        "psr-4": {
            "Depa\\SuluGoogleReviewsBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Depa\\SuluGoogleReviewsBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
